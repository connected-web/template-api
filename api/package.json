{
  "name": "template-api-cdk",
  "version": "0.1.0",
  "bin": {
    "app": "create-stack.ts"
  },
  "scripts": {
    "cdk": "cdk",
    "cdk:synth": "cdk synth",
    "deploy": "cdk deploy",
    "test": "ts-standard && npm run test:unit && npm run test:pre-deployment",
    "test:unit": "vitest run src/tests/unit",
    "test:pre-deployment": "vitest run src/tests/pre-deployment",
    "post-deployment": "npm run test:post-deployment && npm run typegen:for-post-deployment",
    "test:post-deployment": "vitest run src/tests/post-deployment",
    "test:hba": "vitest run src/tests/post-deployment/api-whba-client.test.ts",
    "typegen:for-post-deployment": "typegen src/tests/post-deployment/downloaded-app-openapi.json > src/tests/post-deployment/api-client.d.ts && npm run lint",
    "lint": "ts-standard --fix"
  },
  "author": "Connected Web",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/node": "^25.3.0",
    "@types/prettier": "3.0.0",
    "aws-cdk": "2.1107.0",
    "esbuild": "^0.27.3",
    "openapi-client-axios": "^7.9.0",
    "openapi-client-axios-typegen": "^7.8.0",
    "ts-node": "^10.9.2",
    "ts-standard": "^12.0.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.996.0",
    "@aws-sdk/client-dynamodb": "^3.996.0",
    "@aws-sdk/client-ecr": "^3.996.0",
    "@aws-sdk/client-s3": "^3.996.0",
    "@aws-sdk/lib-dynamodb": "^3.996.0",
    "@connected-web/openapi-rest-api": "^0.8.1",
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "aws-cdk-lib": "2.240.0",
    "aws-jwt-verify": "^5.1.1",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.5",
    "constructs": "^10.5.1",
    "source-map-support": "^0.5.21"
  },
  "ts-standard": {
    "ignore": [
      "cdk.out"
    ]
  }
}
