{
  "name": "template-api-cdk",
  "version": "0.1.0",
  "bin": {
    "app": "create-stack.ts"
  },
  "scripts": {
    "cdk": "cdk",
    "cdk:synth": "cdk synth",
    "deploy": "cdk deploy",
    "test": "ts-standard && npm run test:unit && npm run test:pre-deployment",
    "test:unit": "mocha 'src/tests/unit/**/*.test.ts'",
    "test:pre-deployment": "mocha 'src/tests/pre-deployment/**/*.test.ts'",
    "post-deployment": "npm run test:post-deployment && npm run typegen:for-post-deployment",
    "test:post-deployment": "mocha 'src/tests/post-deployment/**/*.test.ts'",
    "test:hba": "mocha 'src/tests/post-deployment/api-whba-client.test.ts'",
    "typegen:for-post-deployment": "typegen src/tests/post-deployment/downloaded-app-openapi.json > src/tests/post-deployment/api-client.d.ts && npm run lint",
    "lint": "ts-standard --fix"
  },
  "author": "Connected Web",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/chai": "^4.3.14",
    "@types/mocha": "^10.0.6",
    "@types/node": "^24.5.2",
    "@types/prettier": "3.0.0",
    "aws-cdk": "2.1029.2",
    "chai": "^4.4.1",
    "esbuild": "^0.25.10",
    "mocha": "^10.3.0",
    "openapi-client-axios": "^7.7.0",
    "openapi-client-axios-typegen": "^7.7.0",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-standard": "^12.0.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.893.0",
    "@aws-sdk/client-dynamodb": "^3.893.0",
    "@aws-sdk/client-ecr": "^3.893.0",
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/lib-dynamodb": "^3.893.0",
    "@connected-web/openapi-rest-api": "^0.6.4",
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "aws-cdk-lib": "2.215.0",
    "aws-jwt-verify": "^5.1.0",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.12.2",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "ts-standard": {
    "ignore": [
      "cdk.out"
    ]
  }
}
