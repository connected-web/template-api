      },
      "disallowedHeaders": [
        "Cookie",
        "Set-Cookie",
        "X-Forwarded-For"
      ],
      "disallowedHeaderRegexes": [
        "^Proxy-.*$",
        "^X-Real-IP$"
      ]
    }
  }
